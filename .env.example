# ── Playwright Test Environment ──────────────────────────────────────────────
# Copia este archivo como .env y ajusta los valores para tu entorno.
# Las variables se pasan al correr los tests:
#   BASE_URL=https://staging.com npm run test:csv

# URL base del entorno a probar
BASE_URL=http://localhost:5173

# Credenciales de login para los tests
TEST_USER=gerente
TEST_PASS=aurrera2024

# Ruta al archivo CSV de datos de prueba (relativa a la raíz del proyecto)
CSV_PATH=tests/clientes.csv

# (Opcional) Ruta a un Chrome/Chromium ya instalado en el sistema.
# Útil en redes corporativas donde npx playwright install falla por proxy (error 407).
# Windows: PLAYWRIGHT_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS:   PLAYWRIGHT_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PLAYWRIGHT_EXECUTABLE_PATH=
